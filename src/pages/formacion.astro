---
import Layout from "@layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Promo from "../components/Promo.astro";
import Section from "../components/Section.astro";

const FORMACION = {
  layout: {
    title: "Formación",
    description:
      "La industria del software evoluciona y tu también; no es magIA, es tecnología.",
  },
  hero: {
    title: "Formación",
    subtitle:
      "La industria del software evoluciona y tu también; no es magIA, es tecnología.",
    cta: {
      text: "Learn to code Smarter",
      link: "",
    },
  },
  services: {
    title: "¿En qué te puedo formar?",
    subtitle:
      "Ofrezco servicios como freelance para academias y consultoras del sector TI.",
    cards: [
      {
        title: "AI-DD",
        description:
          "Aprende la metodología AI-Driven Development para aumentar la productividad sin perder calidad.",
      },
      {
        title: "Clean Code",
        description:
          "Aprende a desarrollar un software más mantenible y escalable para adaptarlo al futuro.",
      },
      {
        title: "Testing",
        description:
          "Aprende a probar tu código y su funcionalidad para ganar tranquilidad y confianza.",
      },
    ],
  },
  testing: {
    title: "Testing",
    subtitle: "Aprende a probar tu código para ganar tranquilidad.",
    cards: [
      {
        title: "Jest o Vitest",
        description:
          "Pruebas unitarias de Node, Angular y cualquier variante de JavaScript.",
      },
      {
        title: "Playwright",
        description: "Versatilidad, velocidad e integración con IA.",
      },
    ],
  },
  aidd: {
    title: "Desarrollo con IA",
    subtitle: "La IA no te quitará el trabajo, pero lo cambiará para siempre.",
    cards: [
      {
        title: "Metodología",
        description:
          "Aplica la metodología AI-Driven Development a todo el ciclo de desarrollo.",
      },
      {
        title: "Editores",
        description:
          "Domina los AI powered IDEs más usados en el mercado: Copilot en Vscode, Cursor, ClaudeCode...",
      },
    ],
    cta: {
      text: "Más en AIcode Academy",
      link: "https://aicode.academy/cursos/",
    },
  },
  clean: {
    title: "Buenas prácticas",
    subtitle:
      "Aprende a desarrollar un software más mantenible y escalable... en un mundo con IA",
    cards: [
      {
        title: "Clean Code",
        description:
          "Los básicos para humanos y agentes: nombres, complejidad, convenios, funciones y clases. Y un poco de documentación y pruebas.",
      },
      {
        title: "Patrones de diseño",
        description:
          "Evita code-smells aplicando patrones de diseño: estructurales, de comportamiento y de creación.",
      },
    ],
  },
  ediciones: {
    title: "Ediciones",
    subtitle: "Todos los cursos se pueden bonificar por FUNDAE.",
    cards: [
      {
        title: "En directo",
        description:
          "Escoge horarios y días para aprender en directo. Con un temario adaptado a tus necesidades.",
      },
      {
        title: "En video",
        description:
          "Aprende a tu ritmo. Pero con mi ayuda en prácticas y chat de dudas.",
      },
    ],
    cta: {
      text: "Contacta conmigo en LinkedIn",
      link: "https://www.linkedin.com/in/albertobasalo/",
    },
  },
};
---

<Layout layout={FORMACION.layout}>
  <Hero hero={FORMACION.hero} />

  <Section section={FORMACION.services} />
  <Section section={FORMACION.aidd} />
  <Section section={FORMACION.clean} />
  <Section section={FORMACION.testing} />
  <Section section={FORMACION.ediciones} />
  <Promo />
</Layout>
